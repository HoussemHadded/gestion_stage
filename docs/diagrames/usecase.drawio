<mxfile host="app.diagrams.net">
  <diagram name="Use Case Diagram">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Actors -->
        <mxCell id="student" value="Étudiant" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="50" y="200" width="40" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="entreprise" value="Entreprise" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="50" y="350" width="40" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="admin" value="Administrateur" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="50" y="500" width="40" height="80" as="geometry"/>
        </mxCell>

        <!-- System Boundary -->
        <mxCell id="system" value="Plateforme de Gestion des Stages" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="100" width="1000" height="600" as="geometry"/>
        </mxCell>

        <!-- Student Use Cases -->
        <mxCell id="uc1" value="S'inscrire / Se connecter" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="system">
          <mxGeometry x="100" y="100" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="uc2" value="Consulter les offres" style="ellipse;" vertex="1" parent="system">
          <mxGeometry x="100" y="200" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="uc3" value="Postuler à une offre" style="ellipse;" vertex="1" parent="system">
          <mxGeometry x="100" y="300" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="uc4" value="Suivre candidature" style="ellipse;" vertex="1" parent="system">
          <mxGeometry x="100" y="400" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- Entreprise Use Cases -->
        <mxCell id="uc5" value="Publier une offre" style="ellipse;" vertex="1" parent="system">
          <mxGeometry x="500" y="200" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="uc6" value="Gérer les offres" style="ellipse;" vertex="1" parent="system">
          <mxGeometry x="500" y="300" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="uc7" value="Gérer les candidatures" style="ellipse;" vertex="1" parent="system">
          <mxGeometry x="500" y="400" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- Admin Use Cases -->
        <mxCell id="uc8" value="Gérer utilisateurs" style="ellipse;" vertex="1" parent="system">
          <mxGeometry x="800" y="200" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="uc9" value="Superviser offres" style="ellipse;" vertex="1" parent="system">
          <mxGeometry x="800" y="300" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="uc10" value="Voir statistiques" style="ellipse;" vertex="1" parent="system">
          <mxGeometry x="800" y="400" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- Connections -->
        <mxCell id="e1" edge="1" source="student" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" edge="1" source="student" target="uc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" edge="1" source="student" target="uc3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" edge="1" source="student" target="uc4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e5" edge="1" source="entreprise" target="uc5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" edge="1" source="entreprise" target="uc6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" edge="1" source="entreprise" target="uc7" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e8" edge="1" source="admin" target="uc8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" edge="1" source="admin" target="uc9" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" edge="1" source="admin" target="uc10" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>